{
  "name": "css-minecraft-skin-viewer",
  "version": "0.0.1",
  "description": "A pure CSS 3D Minecraft skin viewer for React. Supports poses, animations, effects, outline, skull, cape, face views. SSR-compatible. Zero runtime dependencies.",
  "author": "Nolly",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": ["minecraft", "skin", "viewer", "3d", "css", "react", "component", "cape", "skull", "face", "pose", "animation", "ssr", "typescript", "nextjs", "pixelated", "skin-viewer", "minecraft-skin", "player", "effects", "spin", "walking", "wind", "outline", "npm"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}